{
  "name": "@knoblab/knds",
  "version": "1.0.0",
  "description": "KNDS (Knoblab Design System): Physical-Digital Fusion Interface Design Language & Token Engine",
  "main": "knds.css",
  "type": "module",
  "bin": {
    "knds": "./compiler/cli.js"
  },
  "exports": {
    ".": "./knds.css",
    "./compiler": "./compiler/index.js",
    "./postcss": "./compiler/postcss.js"
  },
  "files": [
    "knds.css",
    "README.md",
    "compiler"
  ],
  "scripts": {
    "dev": "npm --workspace=@knoblab/knds-docs run dev",
    "build": "npm --workspace=@knoblab/knds-docs run build",
    "preview": "npm --workspace=@knoblab/knds-docs run preview",
    "dev:docs": "npm --workspace=@knoblab/knds-docs run dev",
    "build:docs": "npm --workspace=@knoblab/knds-docs run build",
    "preview:docs": "npm --workspace=@knoblab/knds-docs run preview"
  },
  "workspaces": [
    "docs",
    "template/*"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/knoblab/KNDS.git"
  },
  "keywords": [
    "design-language",
    "design-tokens",
    "design-system",
    "tactile-feedback",
    "hardware-ui",
    "knoblab",
    "knds",
    "physical-digital-fusion",
    "dieter-rams",
    "achromatic-ui"
  ],
  "author": "Knoblab Design Team",
  "license": "MIT"
}
